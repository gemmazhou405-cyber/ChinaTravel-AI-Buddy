# Frontend-safe payment mode. Keep production on manual until Sandbox QA is approved.
VITE_PAYMENT_MODE=manual

# Cloudflare Pages Functions secrets / environment variables.
PAYMENT_MODE=manual
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MERCHANT_ID=
FIREBASE_PROJECT_ID=chinaease-buddy
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ALLOWED_ORIGINS=https://chinaeasebuddy.com,http://localhost:5173,http://127.0.0.1:5173

# Buddy AI server-side proxy. Keep these in Cloudflare Pages Functions env/secrets.
COZE_WORKER_URL=
COZE_BOT_ID=
COZE_INTERNAL_SECRET=

# Gumroad webhook automation. Set GUMROAD_WEBHOOK_SECRET to any random string (32+ chars).
# Add ?secret=<GUMROAD_WEBHOOK_SECRET> to the end of the Ping URL in Gumroad Settings > Advanced.
GUMROAD_WEBHOOK_SECRET=
GUMROAD_TRIP_PERMALINK=oentc
GUMROAD_GROUP_PERMALINK=mbgkxz

# Manual admin activation endpoint. Set ADMIN_SECRET to any random string (32+ chars).
# Usage: POST /api/admin/activate with Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=
